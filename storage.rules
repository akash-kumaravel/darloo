rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow read access to all users
    match /{allPaths=**} {
      allow read: if true;
    }

    // Memories folder: All authenticated users can upload
    match /memories/{fileName} {
      allow write: if request.auth != null;
    }

    // Gifts folder: Admin users can upload
    match /gifts/{fileName} {
      allow write: if request.auth != null && 
        request.auth.token.email in ["admin@starfall.com", "akashkumaravel3@gmail.com"];
    }
  }
}
